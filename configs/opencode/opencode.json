{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@plannotator/opencode@latest", "@datadog/opencode-plugin"],
  "mcp": {
    "dev-mcp": {
      "type": "local",
      "command": ["/Users/josephhaaga/.config/opencode/dev-mcp"],
      "enabled": false,
      "environment": {}
    },
    "datadog": {
      "type": "remote",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp?referrer_ide=opencode-plugin&plugin_version=0.7.13",
      "oauth": {}
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "raindrop": {
      "type": "local",
      "command": [
        "/Users/josephhaaga/.raindrop/bin/raindrop",
        "workshop",
        "mcp"
      ],
      "enabled": true,
      "environment": {}
    }
  },
  "agent": {
    "title": {
      "model": "github-copilot/gpt-5.4-mini"
    }
  }
}
