{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    ["./plugins/raindrop-watchdog.ts", {
      "alertNotification": true,
      "alertLogPath": "~/.local/share/opencode/raindrop-watchdog.log",
      "pendingDir": "~/.local/share/opencode/raindrop-watchdog",
      "dbPath": "~/.raindrop/raindrop_workshop.db",
      "verifyDelayMs": 12000
    }],
    "@raindrop-ai/opencode-plugin"
  ],
  "mcp": {
    "dev-mcp": {
      "type": "local",
      "command": ["/Users/josephhaaga/.config/opencode/dev-mcp"],
      "enabled": false,
      "environment": {}
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "raindrop": {
      "type": "local",
      "command": [
        "/Users/josephhaaga/.raindrop/bin/raindrop",
        "workshop",
        "mcp"
      ],
      "enabled": true,
      "environment": {}
    }
  }
}
