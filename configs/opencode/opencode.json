{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@plannotator/opencode@latest",
    "@datadog/opencode-plugin",
    "./local-plugins/hub.ts",
    [
      "opencode-agent-profiler",
      {
        "traceLog": "/tmp/ap-trace.log",
        "captureContent": true,
        "captureHeaders": true,
        "maxAttrChars": 200000,
        "hideInputs": false,
        "hideOutputs": false,
        "hideInputMessages": false,
        "hideOutputMessages": false
      }
    ]
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    }
  },
  "agent": {
    "title": {
      "model": "github-copilot/gpt-5.4-mini"
    },
    "plan": {
      "model": "github-copilot/claude-opus-4.8"
    }
  }
}
