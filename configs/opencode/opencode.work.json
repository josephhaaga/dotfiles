{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/Documents/code/mono/**": "allow",
      "~/Documents/code/omni/**": "allow"
    }
  },
  "mcp": {
    "dev-mcp": {
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "vibe-mcp": {
      "type": "remote",
      "url": "https://mcp.vibe.buzzfeed.ai/mcp",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    }
  }
}
