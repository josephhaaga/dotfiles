{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "dev-mcp": {
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "vibe-mcp": {
      "type": "remote",
      "url": "https://mcp.vibe.buzzfeed.ai/mcp",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    }
  }
}
